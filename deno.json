{
  "compilerOptions": {
    "jsx": "react",
    "jsxFactory": "html",
    "jsxFragmentFactory": "html",
    "jsxImportSource": "book-binder"
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "fmt": {
    "options": {
      "useTabs": false,
      "lineWidth": 120,
      "indentWidth": 2
    }
  },
  "importMap": "imports.json",
  "tasks": {
    "build": "cd ../book-binder && deno task exec $INIT_CWD/src $INIT_CWD/bin"
  }
}